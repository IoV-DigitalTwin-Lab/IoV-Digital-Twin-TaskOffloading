<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<launchConfiguration type="org.omnetpp.ide.run.launchConfigurationType">
<stringAttribute key="bad_container_name" value="/IoV-Digital-Twin-TaskOffloading/.launche"/>
