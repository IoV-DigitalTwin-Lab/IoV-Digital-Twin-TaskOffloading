<booleanAttribute key="org.omnetpp.ide.run.DEBUGGER_ATTACH_ON_STARTUP" value="false"/>
<stringAttribute key="org.omnetpp.ide.run.EXE_FILENAME" value="IoV-Digital-Twin-TaskOffloading"/>
<booleanAttribute key="org.omnetpp.ide.run.EXE_IN_PROJECT_ROOT" value="false"/>
<stringAttribute key="org.omnetpp.ide.run.EXTRA_ARGS" value=""/>
<stringAttribute key="org.omnetpp.ide.run.INI_FILENAME" value="omnetpp.ini"/>
<booleanAttribute key="org.omnetpp.ide.run.INI_IN_PROJECT_ROOT" value="true"/>
<stringAttribute key="org.omnetpp.ide.run.LIBRARIES_TO_LOAD" value="${workspace_loc:/inet}/src/INET ${workspace_loc:/veins}/src/veins"/>
<stringAttribute key="org.omnetpp.ide.run.NED_EXCLUSIONS" value=""/>
<stringAttribute key="org.omnetpp.ide.run.NED_FOLDERS" value=". ${workspace_loc:/inet}/src ${workspace_loc:/veins}/src/veins"/>
