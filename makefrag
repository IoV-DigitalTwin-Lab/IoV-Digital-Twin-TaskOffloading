## Project make fragment to ensure extra linker flags are included for all build systems
# Framework roots (set via environment for portability, with sensible defaults)
ifndef INET_PROJ
INET_PROJ = $(abspath ../../inet4.5)
endif
ifndef VEINS_PROJ
VEINS_PROJ = $(abspath ../../veins-5.3.1)
endif

# Override MSGCOPTS to include framework paths (must be done here, after defaults are set)
MSGCOPTS = $(INCLUDE_PATH) -I$(INET_PROJ)/src -I$(VEINS_PROJ)/src

# INET framework support
INCLUDE_PATH += -I$(INET_PROJ)/src
CFLAGS += -I$(INET_PROJ)/src
MSGCOPTS += -I$(INET_PROJ)/src
LIBS += $(LDFLAG_LIBPATH)$(INET_PROJ)/src -lINET$(D)

# Veins framework support
INCLUDE_PATH += -I$(VEINS_PROJ)/src
CFLAGS += -I$(VEINS_PROJ)/src
MSGCOPTS += -I$(VEINS_PROJ)/src
LIBS += $(LDFLAG_LIBPATH)$(VEINS_PROJ)/src -lveins$(D)

# Ensure libcurl is linked (needed by rsu_http_poster)
LIBS += -L/lib/x86_64-linux-gnu -l:libcurl.so.4

# PostgreSQL support (needed by MyRSUApp)
CFLAGS += -I/usr/include/postgresql
INCLUDE_PATH += -I/usr/include/postgresql
LIBS += -lpq

# Redis support (needed by RedisDigitalTwin)
CFLAGS += -I/usr/include/hiredis
LIBS += -lhiredis
